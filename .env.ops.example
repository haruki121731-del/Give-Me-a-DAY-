# .env.ops.example — Give Me a DAY Ops Environment Variables
# Copy this file: cp .env.ops.example .env.ops
# Load before running: source .env.ops
# Then run: bash ops/run.sh

# ═══════════════════════════════════════════
# REQUIRED — at least one LLM key
# ═══════════════════════════════════════════

# OpenRouter API key (used by generate_daily_report.sh)
# Get: https://openrouter.ai/keys
# Note: Requires credits. Free tier may be limited.
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Anthropic API key — fallback LLM + backend pipeline
# Get: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ═══════════════════════════════════════════
# REQUIRED FOR SUPABASE LOGGING (optional)
# ═══════════════════════════════════════════

# Supabase project URL
# Get: Supabase dashboard → Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase Service Role key (bypasses RLS — keep secret)
# Get: Supabase dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ═══════════════════════════════════════════
# REQUIRED FOR GIT PUSH (optional)
# ═══════════════════════════════════════════

# GitHub Personal Access Token (repo scope)
# Needed for generate_daily_report.sh to push the report back to the repo
# Get: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# ═══════════════════════════════════════════
# OPTIONAL — feature flags
# ═══════════════════════════════════════════

# FRED macro data API key (if absent, macro data is skipped)
# Get: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=YOUR_FRED_KEY_HERE

# ═══════════════════════════════════════════
# VERIFICATION
# ═══════════════════════════════════════════
# After setting vars, verify with:
#   source .env.ops && bash ops/run.sh --check-only
#
# Expected output:
#   ✅ LLM via OpenRouter (OPENROUTER_API_KEY)
#   ✅ LLM via Anthropic  (ANTHROPIC_API_KEY)
#   ✅ Supabase URL (SUPABASE_URL)
#   ✅ Supabase service role key (SUPABASE_SERVICE_ROLE_KEY)
#   ✅ GitHub token (git push)
#   Preflight: ✅ all checks passed
